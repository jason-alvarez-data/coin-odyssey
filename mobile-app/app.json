{
  "expo": {
    "name": "Coin Odyssey",
    "slug": "coin-odyssey",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "coin-odyssey",
    "description": "Professional coin collection management for numismatists. Track, organize, and analyze your coin collection with premium features.",
    "keywords": [
      "coin",
      "collecting",
      "numismatics",
      "collection",
      "management",
      "tracker",
      "catalog"
    ],
    "privacy": "public",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0b09"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.coinodyssey.mobile",
      "buildNumber": "1.0.0",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs access to camera to photograph coins for your collection.",
        "NSPhotoLibraryUsageDescription": "This app needs access to photo library to select coin images."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffc93c"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.coinodyssey.mobile",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "This app needs access to camera to photograph coins for your collection.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "This app needs access to photo library to select coin images.",
          "microphonePermission": false
        }
      ],
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "@sentry/react-native/expo",
        {
          "organization": "REPLACE_WITH_SENTRY_ORG_SLUG",
          "project": "coin-odyssey"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
