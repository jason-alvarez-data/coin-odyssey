# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: Development settings
EXPO_PUBLIC_DEV_MODE=true
EXPO_PUBLIC_API_BASE_URL=https://api.coinodyssey.com

# Crash reporting (Sentry) — leave DSN unset to disable reporting entirely.
# Get the DSN from your Sentry project: Settings → Client Keys (DSN).
EXPO_PUBLIC_SENTRY_DSN=
# Reported as the event environment; also gates reporting (no events when 'development').
EXPO_PUBLIC_ENVIRONMENT=development
# Optional release string for matching uploaded source maps (e.g. coin-odyssey@1.0.0).
EXPO_PUBLIC_RELEASE=

# Source-map UPLOAD (EAS build only) is handled by the @sentry/react-native config plugin.
# It needs an auth token at build time — set this as an EAS secret, NOT in this file:
#   eas secret:create --name SENTRY_AUTH_TOKEN --value <token> --scope project
# and replace the organization slug in app.json's plugin config.