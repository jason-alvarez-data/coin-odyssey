{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_DEV_MODE": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_DEV_MODE": "false"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "entitlements": {
          "aps-environment": "production"
        }
      },
      "android": {
        "buildType": "aab"
      },
      "env": {
        "EXPO_PUBLIC_DEV_MODE": "false"
      }
    },
    "production-apk": {
      "extends": "production",
      "android": {
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "jason.d.alvarez90@gmail.com",
        "ascAppId": "",
        "appleTeamId": ""
      },
      "android": {
        "serviceAccountKeyPath": "",
        "track": "internal"
      }
    }
  }
}
